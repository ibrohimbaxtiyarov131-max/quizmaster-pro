# QuizMaster Pro — Environment Variables
# Скопируйте этот файл в .dev.vars для локальной разработки
# Для production: wrangler secret put PAYME_MERCHANT_ID

# ── Payme Business ────────────────────────────────────────────────────────────
# Получить в кабинете: https://business.payme.uz → Кассы → Настройки

# Merchant ID (одинаков для test и prod)
PAYME_MERCHANT_ID=

# Ключ для продакшн-среды (получите после прохождения модерации)
PAYME_SECRET_KEY=

# Ключ для тестовой среды (доступен сразу после регистрации)
PAYME_TEST_SECRET_KEY=

# Режим: 'true' = тест (sandbox), 'false' = продакшн
PAYME_TEST_MODE=true

# ── Приложение ────────────────────────────────────────────────────────────────
# Публичный URL вашего приложения (для redirect после оплаты)
APP_URL=https://your-project.pages.dev
