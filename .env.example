# Переменные окружения QuizMaster Pro
# Скопируйте этот файл как .dev.vars для локальной разработки
# Для продакшена используйте: npx wrangler pages secret put VARIABLE_NAME

# ──────────────────────────────────────
# PAYME BUSINESS — платёжный шлюз
# Получить на: https://business.payme.uz
# ──────────────────────────────────────

# ID мерчанта из кабинета Payme Business
PAYME_MERCHANT_ID=

# Секретный ключ для продакшена (получить после верификации)
PAYME_SECRET_KEY=

# Секретный ключ для тестового режима (test.payme.uz)
PAYME_TEST_SECRET_KEY=

# Режим работы: true = тест (test.payme.uz), false = боевой (checkout.payme.uz)
PAYME_TEST_MODE=true

# ──────────────────────────────────────
# ПРИЛОЖЕНИЕ
# ──────────────────────────────────────

# Публичный URL вашего приложения (нужен для return_url после оплаты)
# Пример: https://quizmaster-pro.pages.dev
APP_URL=https://your-project.pages.dev
